MONGO_URI=mongodb+srv://<seu_usuario>:<sua_senha>@cluster0.xxxxx.mongodb.net/<nome_do_banco>?retryWrites=true&w=majority
JWT_SECRET=uma_chave_secreta_qualquer_aqui
PORT=5000

# CREDENCIAIS DO ADM
ADMIN_EMAIL=email
ADMIN_PASSWORD=senha

# REDIS (fila de emails - BullMQ)
# URL completa de conexão. No Render, use a Internal Key Value URL (redis://...)
# ou a External (rediss://... com TLS). Em dev local: redis://127.0.0.1:6379
REDIS_URL=redis://127.0.0.1:6379

# ENVIO DE EMAIL (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=seu_email@gmail.com
EMAIL_PASS=sua_senha_de_app
EMAIL_FROM="Arena Gincanas <noreply@gincana.com>"
FRONTEND_URL=http://localhost:3000